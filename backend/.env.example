# Copie para .env e preencha com seus valores reais. NÃO commite o .env.

# URL de conexão com o MongoDB (use seu próprio cluster)
MONGODB_URI=mongodb+srv://USUARIO:SENHA@cluster.mongodb.net/resgatinhos_db?retryWrites=true&w=majority

# Porta do backend
PORT=5000

# Segredo do JWT (gere com: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))")
JWT_SECRET=troque_isto_por_uma_string_aleatoria_longa

# Origem permitida pelo CORS (URL do frontend em dev)
CORS_ORIGIN=http://localhost:5173

# Ambiente (development | production)
NODE_ENV=development
